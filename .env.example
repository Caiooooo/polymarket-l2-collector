# ─── Coins & Intervals ─────────────────────────────────────────────
# Comma-separated list of coins to track (lowercase)
# COINS=btc,eth,sol,xrp
COINS=btc,eth

# Comma-separated list of intervals (5m, 15m)
INTERVALS=5m,15m

# Directions to subscribe (up only, or up,down for full orderbook)
# DIRECTIONS=up,down
DIRECTIONS=up

# ─── Data Storage ──────────────────────────────────────────────────
# Root directory for Parquet data output
DATA_DIR=data

# Flush thresholds: number of messages before writing to disk
FLUSH_THRESHOLD_TRADES=50
FLUSH_THRESHOLD_BOOK=30

# Max cached windows kept in memory (older ones flushed automatically)
MAX_CACHED_WINDOWS=30

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to "json" for structured JSON output (recommended for production)
LOG_FORMAT=plain

# ─── Memory Protection ─────────────────────────────────────────────
MEMORY_SOFT_LIMIT_MB=300
MEMORY_HARD_LIMIT_MB=400

# ─── Health Check ──────────────────────────────────────────────────
# Seconds before binance price is considered stale → restart session
BINANCE_STALE_SECONDS=300
# Seconds before poly WS data is considered stale → restart session
POLY_WS_STALE_SECONDS=600

# ─── Daily Restart ──────────────────────────────────────────────────
RESTART_HOUR=3
RESTART_MINUTE=0
